---
import { getCollection, render, type CollectionEntry } from "astro:content";
import SearchOverlay from "../../components/SearchOverlay.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSortedPosts, type PostSummary } from "../../lib/posts";

interface Props {
  post: CollectionEntry<"posts">;
  allPosts: PostSummary[];
}

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const allPosts: PostSummary[] = getSortedPosts(posts.map((entry: CollectionEntry<"posts">) => ({
    slug: entry.slug,
    title: entry.data.title,
    date: entry.data.date,
    summary: entry.data.summary,
    tags: entry.data.tags,
    featured: entry.data.featured,
    readTime: entry.data.readTime,
    href: `/posts/${entry.slug}/`,
  })));

  return posts.map((post: CollectionEntry<"posts">) => ({
    params: { slug: post.slug },
    props: { post, allPosts },
  }));
}

const { post, allPosts } = Astro.props as Props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} · gaoguobin`}
  description={post.data.summary}
  activePath="/archive/"
>
  <article class="post-card" aria-labelledby="post-title">
    <p class="meta">
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString("en", { year: "numeric", month: "short", day: "numeric" })}
      </time>
      <span> · {post.data.readTime}</span>
    </p>
    <h1 id="post-title">{post.data.title}</h1>
    <p>{post.data.summary}</p>
    <div class="tag-row" aria-label="Post topics">
      {post.data.tags.map((tag: string) => (
        <a class="tag" href={`/topics/${encodeURIComponent(tag.trim().toLowerCase())}/`}>{tag}</a>
      ))}
    </div>
    <Content />
  </article>

  <SearchOverlay posts={allPosts} />
</BaseLayout>

<script>
  import "../../scripts/home-interactions";
</script>
