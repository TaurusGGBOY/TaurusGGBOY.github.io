---
import type { TopicSummary } from "../lib/posts";

interface Props {
  topics: TopicSummary[];
}

const { topics } = Astro.props;
---

<section class="topic-filter" data-topic-filter aria-labelledby="topic-filter-heading">
  <div class="dialog-head">
    <h2 id="topic-filter-heading">Topics</h2>
    <button class="button" type="button" data-topic-reset>All writing</button>
  </div>
  <div class="topic-list" aria-label="Filter writing by topic">
    {topics.map((topic) => (
      <button class="topic-button" type="button" data-topic={topic.name}>
        <span>{topic.name}</span>
        <span class="topic-count">{topic.count}</span>
      </button>
    ))}
  </div>
</section>
