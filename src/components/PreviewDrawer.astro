---
import type { PostSummary } from "../lib/posts";

interface Props {
  posts: PostSummary[];
}

const { posts } = Astro.props;
---

<aside
  class="drawer"
  data-preview-drawer
  role="dialog"
  aria-modal="true"
  aria-labelledby="preview-drawer-title"
  hidden
>
  <div class="dialog-head">
    <h2 id="preview-drawer-title">Preview</h2>
    <button class="icon-button" type="button" aria-label="Close preview" data-preview-close>Close</button>
  </div>

  <div class="preview-panels">
    {posts.map((post) => (
      <section class="preview-panel" data-preview-panel={post.slug} hidden>
        <div class="meta">
          <time datetime={post.date.toISOString()}>
            {post.date.toLocaleDateString("en", { year: "numeric", month: "short", day: "numeric" })}
          </time>
          <span> · {post.readTime}</span>
        </div>
        <h3>{post.title}</h3>
        <p>{post.summary}</p>
        <div class="tag-row">
          {post.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <div class="post-actions">
          <a class="button primary" href={post.href}>Read article</a>
          <button class="button" type="button" data-queue-add={post.slug}>Add to queue</button>
        </div>
      </section>
    ))}
  </div>
</aside>
