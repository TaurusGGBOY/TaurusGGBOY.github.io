{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "astro.config.mjs",
    "playwright.config.ts",
    "src/**/*",
    "tests/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    ".astro",
    "Archives",
    "categories",
    "css",
    "dist",
    "images",
    "js",
    "lib",
    "node_modules",
    "page",
    "posts",
    "vendors"
  ]
}
