+def parse_general_html(text):
+    results = []
+    dom = html.fromstring(text)
+
+    for article in dom.xpath('//article[@rl-link-data-url]'):
+        url = article.get('rl-link-data-url')
+        title_nodes = article.xpath('.//*[@role="title"]')
+        if not url or not title_nodes:
+            continue
+
+        title = html_to_text(' '.join(title_nodes[0].itertext())).strip()
+        summary_nodes = article.xpath('.//*[contains(@class, "summary-text")]')
+        content = ''
+        if summary_nodes:
+            content = html_to_text(' '.join(summary_nodes[0].itertext())).strip()
+
+        if title:
+            results.append({'title': title, 'url': url, 'content': content})
+
+    if not results:
+        raise SearxEngineAPIException("Invalid mobile HTML response")
+    return results
+
+
+def fetch_general_json(query, page_start, headers):
+    url = 'https://www.baidu.com/s'
+    params = {'wd': query, 'rn': results_per_page, 'pn': page_start, 'tn': 'json'}
+
+    for proxy in baidu_fallback_proxies:
+        try:
+            with httpx.Client(proxy=proxy, timeout=10, follow_redirects=False, http2=False) as client:
+                response = client.get(url, params=params, headers=dict(headers))
+            if response.status_code != 200:
+                continue
+            data = response.json()
+            if data.get('antiFlag') == 1:
+                continue
+            return parse_general(data)
+        except (httpx.HTTPError, ValueError, SearxEngineAPIException):
+            continue
+    return []
+
